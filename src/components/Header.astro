---
import { Icon } from 'astro-icon/components';
import { SITE_TITLE, NAV_LINKS } from '../consts';
import { primarySocialLinks } from '../lib/social';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">{SITE_TITLE}</a>
		<div class="internal-links">
			{NAV_LINKS.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
		</div>
		<div class="social-links">
			{
				primarySocialLinks.map((link) => (
					<a href={link.url} target="_blank" rel="me noopener" title={link.label}>
						<span class="sr-only">{link.label}</span>
						<Icon name={link.icon} width={20} height={20} />
					</a>
				))
			}
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		border-bottom: 1px solid var(--rule);
		background: rgba(250, 243, 224, 0.6);
		backdrop-filter: blur(4px);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		max-width: var(--wide-width);
		margin: 0 auto;
		flex-wrap: wrap;
	}
	.brand {
		font-family: var(--font-essay);
		font-weight: 600;
		font-size: 1.25rem;
		color: var(--ink);
		text-decoration: none;
		padding: 0.8em 0;
	}
	.internal-links {
		display: flex;
		gap: 0.25em;
		flex-wrap: wrap;
	}
	nav a {
		padding: 0.5em 0.6em;
		color: var(--ink-soft);
		text-decoration: none;
	}
	.internal-links :global(a.active) {
		color: var(--accent);
		font-weight: 600;
	}
	.social-links {
		display: flex;
		gap: 0.5em;
		color: var(--ink-soft);
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
