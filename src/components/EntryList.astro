---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import type { ImageMetadata } from 'astro';

export interface EntryItem {
	href: string;
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: ImageMetadata;
}

interface Props {
	items: EntryItem[];
	/** Controls the typographic voice of the titles. */
	variant?: 'essay' | 'tech';
}

const { items, variant = 'tech' } = Astro.props;
---

<ul class:list={['entry-list', `variant-${variant}`]}>
	{
		items.map((item) => (
			<li>
				<a href={item.href}>
					{item.heroImage ? (
						<div class="thumb">
							<Image src={item.heroImage} alt="" width={320} densities={[1.5, 2]} />
						</div>
					) : (
						<div class="thumb thumb--empty" aria-hidden="true" />
					)}
					<div class="text">
						<h2>{item.title}</h2>
						<p class="desc">{item.description}</p>
						<FormattedDate date={item.pubDate} />
					</div>
				</a>
			</li>
		))
	}
</ul>

<style>
	.entry-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.entry-list li {
		border-bottom: 1px solid var(--rule);
	}
	.entry-list a {
		display: flex;
		align-items: center;
		gap: 1.25em;
		padding: 1.25em 0;
		text-decoration: none;
		color: inherit;
	}

	/* Cover thumbnail — fixed box, cropped. Reserves space even when absent so
	   rows with and without a cover stay vertically aligned. */
	.thumb {
		flex: 0 0 auto;
		width: 96px;
		height: 64px;
		border-radius: 6px;
		overflow: hidden;
		background: var(--paper-raised);
		border: 1px solid var(--rule);
	}
	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		border-radius: 0;
	}
	/* Graceful empty state: a faint sepia placeholder, no broken image. */
	.thumb--empty {
		background:
			repeating-linear-gradient(
				45deg,
				var(--paper-raised),
				var(--paper-raised) 6px,
				var(--paper) 6px,
				var(--paper) 12px
			);
		opacity: 0.7;
	}

	.text {
		min-width: 0;
	}
	.entry-list h2 {
		margin: 0 0 0.15em;
		font-size: 1.3rem;
		line-height: 1.25;
	}
	.entry-list a:hover h2 {
		color: var(--accent);
	}
	.desc {
		margin: 0 0 0.35em;
		color: var(--ink-soft);
		font-size: 0.95rem;
		/* Keep the list minimal: clamp long descriptions to two lines. */
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.text :global(time) {
		font-family: var(--font-sans);
		font-size: 0.78rem;
		color: var(--ink-faint);
	}

	/* Essay titles wear the editorial serif; tech titles the geometric sans. */
	.variant-essay h2 {
		font-family: var(--font-essay);
		font-weight: 600;
	}
	.variant-essay .desc {
		font-family: var(--font-essay);
	}
	.variant-tech h2 {
		font-family: var(--font-sans);
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	@media (max-width: 520px) {
		.entry-list a {
			gap: 0.9em;
		}
		.thumb {
			width: 72px;
			height: 52px;
		}
		.entry-list h2 {
			font-size: 1.1rem;
		}
	}
</style>
