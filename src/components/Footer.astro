---
import { SITE_AUTHOR, SOCIAL_LINKS } from '../consts';
const today = new Date();
---

<footer>
	<div class="rule"></div>
	<p>
		&copy; {today.getFullYear()} {SITE_AUTHOR}. Set in Newsreader, Space Grotesk &amp; JetBrains
		Mono.
	</p>
	<div class="social-links">
		<a href={SOCIAL_LINKS.github} target="_blank" rel="me noopener">GitHub</a>
		<span>·</span>
		<a href={SOCIAL_LINKS.twitter} target="_blank" rel="me noopener">Twitter</a>
		<span>·</span>
		<a href="/rss.xml">RSS</a>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em 4em;
		text-align: center;
		color: var(--ink-faint);
		font-size: 0.9rem;
	}
	.rule {
		width: 60px;
		height: 1px;
		background: var(--rule);
		margin: 0 auto 2em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 0.6em;
		margin-top: 0.5em;
	}
	.social-links a {
		color: var(--ink-soft);
		text-decoration: none;
	}
	.social-links a:hover {
		color: var(--accent);
	}
</style>
