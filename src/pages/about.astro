---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS } from '../consts';
---

<BaseLayout title="About · Arnav Gupta" description="About Arnav Gupta.">
	<article class="reading-essay">
		<h1>About</h1>
		<p>
			I'm Arnav Gupta — an engineer and writer. This is my corner of the web: a place for
			<a href="/essays">essays</a>, <a href="/posts">technical writing</a>, and
			<a href="/projects">projects</a> I care enough about to document.
		</p>
		<p>
			Replace this copy with your own story. The site is built with
			<a href="https://astro.build">Astro</a>; essays are set in Newsreader, tech writing in Space
			Grotesk, and code in JetBrains Mono.
		</p>
		<p>
			Find me on <a href={SOCIAL_LINKS.github}>GitHub</a> and
			<a href={SOCIAL_LINKS.twitter}>Twitter</a>.
		</p>
	</article>
</BaseLayout>
