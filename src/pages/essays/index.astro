---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryList from '../../components/EntryList.astro';

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const items = essays.map((e) => ({
	href: `/essays/${e.id}/`,
	title: e.data.title,
	description: e.data.description,
	pubDate: e.data.pubDate,
	heroImage: e.data.heroImage,
}));
---

<BaseLayout title="Essays · Arnav Gupta" description="Long-form essays by Arnav Gupta.">
	<header class="page-head">
		<p class="kicker">Essays</p>
		<p class="blurb">On thinking, life, and the questions worth sitting with.</p>
	</header>
	<EntryList items={items} variant="essay" />
</BaseLayout>

<style>
	.kicker {
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.8rem;
		color: var(--accent);
		margin-bottom: 0.2em;
	}
	.blurb {
		font-family: var(--font-essay);
		font-style: italic;
		font-size: 1.25rem;
		color: var(--ink-soft);
		margin-bottom: 2em;
	}
</style>
